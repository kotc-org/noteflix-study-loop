{
  "name": "@noteflix/openai-mcp-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "OAuth 2.1 MCP gateway for private Noteflix notes and separately confirmed public study videos.",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "firebase-admin": "13.10.0",
    "google-auth-library": "10.9.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "20.19.25",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
