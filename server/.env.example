NODE_ENV=development
PORT=8080

# OAuth issuer origin and exact RFC 8707 resource audience.
PUBLIC_BASE_URL=http://localhost:8080
MCP_RESOURCE_URL=http://localhost:8080/mcp
MCP_ALLOWED_ORIGINS=https://chatgpt.com,https://claude.ai
SERVICE_DOCUMENTATION_URL=https://noteflix.com/openai-app

# Service-to-service OIDC audience and user-facing Noteflix app origin.
NOTEFLIX_INTERNAL_AUDIENCE=https://ainotes-uvnha3l3nq-uc.a.run.app
NOTEFLIX_APP_BASE_URL=https://noteflix.com

# Firebase project used by the real Noteflix app.
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_WEB_API_KEY=replace-with-firebase-web-api-key
FIREBASE_WEB_AUTH_DOMAIN=replace-with-project.firebaseapp.com
FIREBASE_WEB_APP_ID=replace-with-firebase-web-app-id

# Generate once with: openssl rand -base64 32
# Store this in Secret Manager in production and keep it stable.
OAUTH_CLIENT_SECRET_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# Keep OAuth, idempotency, and rate-limit state out of the product database.
FIRESTORE_DATABASE_ID=noteflix-openai-mcp
FIRESTORE_COLLECTION_PREFIX=noteflix_openai_mcp

OAUTH_CLIENT_REGISTRATION_TTL_SECONDS=2592000
OAUTH_AUTHORIZATION_REQUEST_TTL_SECONDS=600
OAUTH_AUTHORIZATION_CODE_TTL_SECONDS=300
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
MCP_RATE_LIMIT_PER_MINUTE=30
VIDEO_CREATE_RATE_LIMIT_PER_HOUR=3
CONSENT_RATE_LIMIT_PER_15_MINUTES=60
NOTEFLIX_REQUEST_TIMEOUT_MS=45000
MAX_NOTE_CONTENT_CHARS=50000

# Set only after OpenAI supplies the exact domain-verification value.
# The server returns it alone from /.well-known/openai-apps-challenge.
# OPENAI_APPS_CHALLENGE_TOKEN=replace-with-portal-token
